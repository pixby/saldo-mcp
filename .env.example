# --- Mode ---
# Managed mode: set SALDO_BROKER_URL to point at a running broker. Then you do NOT
# need any EB_* values here — the broker holds the Enable Banking key and mints
# tokens. Leave it unset for self-host mode (bring your own EB app, below).
# SALDO_BROKER_URL=https://localhost:9443

# Where the connector stores link/device state (which accounts are connected).
# No transaction data is ever written here. Defaults to ~/.saldo
# SALDO_DATA_DIR=/Users/you/.saldo

# --- Enable Banking (https://enablebanking.com) ---
# 1. Create a free account and register an Application in the control panel.
# 2. Note the Application ID and download its RSA private key (.pem).
# 3. Register the redirect URL below in the application settings (it must match).
# On the free "Restricted Production" tier you can link your OWN accounts without
# a contract; serving other users requires a signed contract + KYB.

EB_APPLICATION_ID=
# Inline PEM (the same variable the broker/Railway use). In a .env file put it on
# one line with \n escapes (un-escaped at load); a real multi-line PEM also works.
# Convert your .pem to the escaped one-liner with:
#   awk 'NF {printf "%s\\n", $0}' your_key.pem
EB_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Loopback URL the bank redirects to after authentication. Must exactly match the
# redirect URL registered in the Enable Banking application. Enable Banking
# requires https, so the connector serves this with a self-signed localhost cert
# (your browser shows a one-time "not trusted" warning — click through).
EB_REDIRECT_URL=https://localhost:8888/callback
